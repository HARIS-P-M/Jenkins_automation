# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/contact_manager

# JWT Secret
JWT_SECRET=dev_secret_change_me_in_production

# Server Port
PORT=4000

# Frontend Origin(s) for CORS (comma-separated)
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173

# Email Configuration (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Twilio Configuration for SMS
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Note: If Twilio credentials are not configured, the app will run in DEMO mode
# and simulate SMS sending without actually sending messages
